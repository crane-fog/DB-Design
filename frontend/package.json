{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint": "oxlint --fix src/",
    "lint:ci": "oxlint src/",
    "format": "prettier --write src/",
    "format:ci": "prettier --check src/"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "jiti": "^2.6.1",
    "oxlint": "~1.50.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": "This project uses pnpm for package management."
  },
  "packageManager": "pnpm@10.32.1"
